{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rendo.dev/contracts/template-manifest.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "type",
    "templateKind",
    "templateRole",
    "category",
    "title",
    "description",
    "uiMode",
    "domainTags",
    "scenarioTags",
    "runtimeModes",
    "defaultProviders",
    "recommendedPacks",
    "requiredEnv",
    "toolchains",
    "lineage",
    "surfaceCapabilities",
    "defaultSurfaces",
    "surfacePaths",
    "supports",
    "compatibility",
    "assetInstall"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "type": { "enum": ["template"] },
    "templateKind": {
      "enum": [
        "starter-template",
        "feature-template",
        "capability-template",
        "provider-template",
        "surface-template"
      ]
    },
    "templateRole": { "enum": ["core", "base", "derived"] },
    "category": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "uiMode": { "enum": ["none", "web", "miniapp", "mobile", "multi"] },
    "domainTags": { "type": "array", "items": { "type": "string" } },
    "scenarioTags": { "type": "array", "items": { "type": "string" } },
    "runtimeModes": {
      "type": "array",
      "items": { "enum": ["source", "managed", "hybrid"] },
      "minItems": 1
    },
    "defaultProviders": {
      "type": "object",
      "required": ["agent", "workflow", "auth", "db", "cache"],
      "properties": {
        "agent": { "type": "string" },
        "workflow": { "type": "string" },
        "auth": { "type": "string" },
        "db": { "type": "string" },
        "cache": { "type": "string" }
      }
    },
    "recommendedPacks": { "type": "array", "items": { "type": "string" } },
    "requiredEnv": { "type": "array", "items": { "type": "string" } },
    "toolchains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "role"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["coreTemplate", "baseTemplate"],
      "properties": {
        "coreTemplate": { "type": ["string", "null"] },
        "baseTemplate": { "type": ["string", "null"] }
      }
    },
    "surfaceCapabilities": {
      "type": "array",
      "items": { "enum": ["web", "miniapp", "mobile", "desktop"] }
    },
    "defaultSurfaces": {
      "type": "array",
      "items": { "enum": ["web", "miniapp", "mobile", "desktop"] }
    },
    "surfacePaths": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "supports": {
      "type": "object",
      "required": ["web", "miniapp", "mobile", "desktop"],
      "properties": {
        "web": { "type": "boolean" },
        "miniapp": { "type": "boolean" },
        "mobile": { "type": "boolean" },
        "desktop": { "type": "boolean" }
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["cli", "registryProtocol", "hosts"],
      "properties": {
        "cli": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": ["string", "null"] },
            "max": { "type": ["string", "null"] }
          }
        },
        "registryProtocol": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": ["string", "null"] },
            "max": { "type": ["string", "null"] }
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["templateId", "templateKind", "minVersion", "maxVersion"],
            "properties": {
              "templateId": { "type": "string", "minLength": 1 },
              "templateKind": {
                "enum": [
                  "starter-template",
                  "feature-template",
                  "capability-template",
                  "provider-template",
                  "surface-template"
                ]
              },
              "minVersion": { "type": ["string", "null"] },
              "maxVersion": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "assetInstall": {
      "type": ["object", "null"],
      "required": ["previewSummary", "supportedHostKinds", "supportedHostTemplates", "modes"],
      "properties": {
        "previewSummary": { "type": "string", "minLength": 1 },
        "supportedHostKinds": {
          "type": "array",
          "items": {
            "enum": [
              "starter-template",
              "feature-template",
              "capability-template",
              "provider-template",
              "surface-template"
            ]
          }
        },
        "supportedHostTemplates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "modes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["runtimeMode", "targetRoot", "conflictStrategy", "rollbackStrategy", "install"],
            "properties": {
              "runtimeMode": { "enum": ["source", "managed", "hybrid"] },
              "targetRoot": { "type": "string", "minLength": 1 },
              "conflictStrategy": { "enum": ["fail", "overwrite", "skip"] },
              "rollbackStrategy": { "enum": ["safe-abort", "manual"] },
              "install": {
                "type": "object",
                "required": [
                  "addsFiles",
                  "updatesFiles",
                  "deletesFiles",
                  "addsEnv",
                  "addsRoutes",
                  "addsPages",
                  "addsComponents",
                  "addsMigrations",
                  "addsWorkerTasks",
                  "addsAdminModules",
                  "requiresManualSetup"
                ],
                "properties": {
                  "addsFiles": { "type": "array", "items": { "type": "string" } },
                  "updatesFiles": { "type": "array", "items": { "type": "string" } },
                  "deletesFiles": { "type": "array", "items": { "type": "string" } },
                  "addsEnv": { "type": "array", "items": { "type": "string" } },
                  "addsRoutes": { "type": "array", "items": { "type": "string" } },
                  "addsPages": { "type": "array", "items": { "type": "string" } },
                  "addsComponents": { "type": "array", "items": { "type": "string" } },
                  "addsMigrations": { "type": "boolean" },
                  "addsWorkerTasks": { "type": "boolean" },
                  "addsAdminModules": { "type": "boolean" },
                  "requiresManualSetup": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
