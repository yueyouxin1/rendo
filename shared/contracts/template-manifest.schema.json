{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rendo.dev/contracts/template-manifest.schema.json",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "type",
    "templateKind",
    "templateRole",
    "category",
    "title",
    "description",
    "uiMode",
    "domainTags",
    "scenarioTags",
    "runtimeModes",
    "defaultProviders",
    "recommendedPacks",
    "requiredEnv",
    "toolchains",
    "lineage",
    "surfaceCapabilities",
    "defaultSurfaces",
    "surfacePaths",
    "supports"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "type": { "enum": ["core-starter", "domain-starter", "template-asset"] },
    "templateKind": {
      "enum": [
        "starter-template",
        "feature-template",
        "capability-template",
        "provider-template",
        "surface-template"
      ]
    },
    "templateRole": { "enum": ["core", "base", "derived"] },
    "category": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "uiMode": { "enum": ["none", "web", "miniapp", "mobile", "multi"] },
    "domainTags": { "type": "array", "items": { "type": "string" } },
    "scenarioTags": { "type": "array", "items": { "type": "string" } },
    "runtimeModes": {
      "type": "array",
      "items": { "enum": ["source", "managed", "hybrid"] },
      "minItems": 1
    },
    "defaultProviders": {
      "type": "object",
      "required": ["agent", "workflow", "auth", "db", "cache"],
      "properties": {
        "agent": { "type": "string" },
        "workflow": { "type": "string" },
        "auth": { "type": "string" },
        "db": { "type": "string" },
        "cache": { "type": "string" }
      }
    },
    "recommendedPacks": { "type": "array", "items": { "type": "string" } },
    "requiredEnv": { "type": "array", "items": { "type": "string" } },
    "toolchains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "role"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["coreStarter", "baseTemplate"],
      "properties": {
        "coreStarter": { "type": ["string", "null"] },
        "baseTemplate": { "type": ["string", "null"] }
      }
    },
    "surfaceCapabilities": {
      "type": "array",
      "items": { "enum": ["web", "miniapp", "mobile", "desktop"] }
    },
    "defaultSurfaces": {
      "type": "array",
      "items": { "enum": ["web", "miniapp", "mobile", "desktop"] }
    },
    "surfacePaths": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "supports": {
      "type": "object",
      "required": ["web", "miniapp", "mobile", "desktop"],
      "properties": {
        "web": { "type": "boolean" },
        "miniapp": { "type": "boolean" },
        "mobile": { "type": "boolean" },
        "desktop": { "type": "boolean" }
      }
    }
  }
}
