{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rendo.dev/contracts/project-manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "projectName", "surfaces", "template", "installedTemplates", "installedPacks"],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "projectName": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "surfaces": {
      "type": "array",
      "items": { "enum": ["web", "miniapp", "mobile", "desktop"] }
    },
    "template": {
      "type": "object",
      "required": ["id", "templateKind", "templateRole", "version", "runtimeMode", "createdFrom", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "templateKind": { "type": "string" },
        "templateRole": { "type": "string" },
        "version": { "type": "string" },
        "runtimeMode": { "type": "string" },
        "createdFrom": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "origin": {
      "type": "object",
      "required": ["createdBy", "registry", "source", "templateId", "templateKind", "templateRole", "templateVersion", "runtimeMode"],
      "properties": {
        "createdBy": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "minLength": 1 },
        "source": { "enum": ["local", "remote"] },
        "templateId": { "type": "string", "minLength": 1 },
        "templateKind": { "type": "string", "minLength": 1 },
        "templateRole": { "type": "string", "minLength": 1 },
        "templateVersion": { "type": "string", "minLength": 1 },
        "runtimeMode": { "type": "string", "minLength": 1 }
      }
    },
    "installedTemplates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "templateKind",
          "templateRole",
          "runtimeMode",
          "registry",
          "source",
          "bundleDigest",
          "templateDigest",
          "targetPath",
          "installedAt"
        ],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "templateKind": { "type": "string" },
          "templateRole": { "type": "string" },
          "runtimeMode": { "type": "string" },
          "registry": { "type": "string" },
          "source": { "enum": ["local", "remote"] },
          "bundleDigest": { "type": ["string", "null"] },
          "templateDigest": { "type": ["string", "null"] },
          "targetPath": { "type": "string" },
          "installedAt": { "type": "string" }
        }
      }
    },
    "installedPacks": { "type": "array" }
  }
}
