{
  "name": "rendo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "rendo": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
